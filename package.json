{
  "name": "geoflora",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @geoflora/web",
    "dev:server": "npm run dev --workspace @geoflora/server",
    "start": "npm run start --workspace @geoflora/server",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run typecheck --workspaces --if-present"
  }
}
